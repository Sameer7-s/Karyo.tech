GEMINI_API_KEY="your_gemini_api_key_here"
APP_URL="https://your-app-url-here"

# Admin API / database (server-only — never expose to frontend)
DATABASE_URL="your_database_url_here"
MONGODB_URI="your_mongodb_connection_string_here"
MONGODB_DB="karyo"
JWT_SECRET="your_long_random_jwt_secret_here"
JWT_EXPIRES_IN="7d"
ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change_me_before_deploy"
ADMIN_RESET_PASSWORD_ON_START="false"
PORT=5000
CLIENT_URL="http://localhost:3000"

# Public API base used by the frontend (safe to expose)
VITE_API_URL="http://localhost:5000/api"

# Lead notification email (optional, server-only)
LEAD_NOTIFICATION_EMAIL="hello@example.com"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp_user_here"
SMTP_PASS="smtp_password_here"
SMTP_FROM="KARYO <noreply@example.com>"
